# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Gemini API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your-gemini-api-key

# Vertex AI
GEMINI_MODEL_NAME=gemini-2.0-flash

# Firestore
FIRESTORE_COLLECTION=election_guidelines

# Text-to-Speech (enable Cloud TTS API in GCP Console)
ENABLE_TTS=true
TTS_VOICE_NAME=en-IN-Wavenet-A
TTS_LANGUAGE_CODE=en-IN

# Translation (enable Cloud Translation API in GCP Console)
ENABLE_TRANSLATION=true

# Geocoding (enable Geocoding API + get Maps API key)
ENABLE_GEOCODING=false
GEOCODING_API_KEY=

# Application
USE_MOCK_MODE=false
CORS_ORIGINS=http://localhost:3000
